# Puerto del servidor
PORT=3000

# Base de datos PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/cine-gratin

# JWT Secret para autenticación
JWT_SECRET=change-me-to-a-random-secret

# TMDB API Key (opcional, para scraping de metadatos)
TMDB_API_KEY=

# YouTube API Key (opcional, para importación de canales)
YOUTUBE_API_KEY=

# Entorno
NODE_ENV=development

# Log level (trace, debug, info, warn, error, fatal)
LOG_LEVEL=info

# CORS origin
CORS_ORIGIN=http://localhost:5173
