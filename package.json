{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "node node_modules/.bin/vite build",
    "typecheck": "node node_modules/.bin/tsc --noEmit",
    "render:build": "bash render-build.sh",
    "render:start": "node artifacts/api-server/dist/index.mjs",
    "format": "prettier --write \"frontend/src/**/*.{ts,tsx,css}\" \"*.json\" \"*.md\"",
    "format:check": "prettier --check \"frontend/src/**/*.{ts,tsx,css}\" \"*.json\" \"*.md\""
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
